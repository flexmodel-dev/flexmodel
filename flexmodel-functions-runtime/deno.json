{
  "name": "@flexmodel/functions-runtime",
  "version": "0.0.1",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --allow-write --unstable-worker-options --watch src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --unstable-worker-options src/main.ts",
    "test": "deno test --allow-all --unstable-worker-options",
    "test:unit": "deno test --allow-all --unstable-worker-options src/server_test.ts src/router src/runner/registry_test.ts",
    "test:integration": "deno test --allow-all --unstable-worker-options src/runner/worker_test.ts",
    "test:watch": "deno test --allow-all --unstable-worker-options --watch"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.6.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@flexmodel/sdk": "npm:@flexmodel/sdk@0.0.4"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
